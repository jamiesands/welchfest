# Copy to .env.local and fill in.

# Supabase project (welchfest schema, welchfest-photos bucket).
# The public memento pages read with the anon key (RLS is SELECT-only).
NEXT_PUBLIC_SUPABASE_URL=https://virybnhjigtupuiwveke.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-only admin writes (truck placements, the lorry
# winner, penalty-shootout rows) and photo moderation go through this. It
# bypasses RLS, so it must NEVER reach the client. Do NOT prefix NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Moderator key — gate for /moderate and every /api/admin and /api/moderate
# write. proxy.ts checks a digest of this in a cookie set at /moderate/login.
MODERATOR_KEY=

# Soft passphrase that hides the /admin tool UI. NEXT_PUBLIC_, so it ships in
# the client bundle — convenience only, not real auth. The real protection on
# writes is MODERATOR_KEY above.
NEXT_PUBLIC_ADMIN_PASSPHRASE=
