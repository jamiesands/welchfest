# Copy to .env.local and fill in.

# Supabase project (welchfest schema, welchfest-photos bucket).
NEXT_PUBLIC_SUPABASE_URL=https://virybnhjigtupuiwveke.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-only routes (e.g. /moderate) read this via
# SUPABASE_SERVICE_ROLE_KEY. Do NOT prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Passphrase gate for /admin/360 (Jamie's 360 uploader).
# NEXT_PUBLIC_ — visible in the client bundle. This is an internal
# party-day convenience gate, not real auth.
NEXT_PUBLIC_ADMIN_PASSPHRASE=
